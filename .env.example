# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must never be committed.
# See documentation/youtube-api-setup.md for full setup instructions.

# YouTube Data API v3 key (server-only — no NEXT_PUBLIC_ prefix)
YOUTUBE_API_KEY=

# Channel ID for the YouTube channel to pull episodes from (starts with UC)
# Manufacturing Hub: obtain via the API or channel page source
# Personal channel: UC6JpBeS_6JhUwfGF8RgLCIQ
YOUTUBE_CHANNEL_ID=
